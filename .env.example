# PACES Practice — environment variables. Copy to .env.local and fill in.
# Everything below is OPTIONAL: with all of it unset the app runs BYOK-only
# (each user pastes their own API key for the selected model's provider in
# Settings).

# ── Demo access gate (whitelisted magic-link sign-in) ────────────────────────
# Lets a small set of invited users practise on a server-held key with no BYOK
# friction. See SPEC.md "Demo access" and README.md for the full flow.

# Comma-separated emails allowed to request demo access.
# Matched case-insensitively and trimmed; empty/unset = nobody.
DEMO_WHITELIST=consultant@example.com

# Server-held API keys used for valid demo sessions — one per provider, all
# optional; demo mode is on when AT LEAST ONE is set (a session can only use
# models whose provider has a key here). Use spend-capped keys — each is the
# blast radius if abused. None of these ever leave the server.
#
# RECOMMENDED managed path (Phase 0, 2026-07-09): DEMO_GATEWAY_API_KEY. This is
# a Vercel AI Gateway key — ONE key + ONE top-up (in the Vercel dashboard) that
# fans out to BOTH offered models (Claude Sonnet 4.6 + DeepSeek V4 Pro) at zero
# markup. Create it at Vercel → AI Gateway → API Keys, top up the AI Gateway
# credit balance (leave auto-top-up OFF so the balance is a hard no-surprise-charge ceiling — the invited tier simply pauses when it hits zero), then set it here. This is the only demo
# key you need while the app offers the gateway-routed models.
DEMO_GATEWAY_API_KEY=
#
# Direct-provider demo keys (unused while the gateway is the front door; kept
# for BYOK-direct or an off-Vercel fallback). Providers: Anthropic
# (console.anthropic.com), DeepSeek (platform.deepseek.com), Moonshot/Kimi
# (platform.moonshot.ai), MiniMax (platform.minimax.io).
DEMO_ANTHROPIC_API_KEY=
DEMO_DEEPSEEK_API_KEY=
DEMO_MOONSHOT_API_KEY=
DEMO_MINIMAX_API_KEY=

# Secret for HMAC-signing magic-link tokens and the demo_session cookie.
# Required for demo mode. Generate one with: openssl rand -hex 32
AUTH_SECRET=

# ── SMTP (magic-link email delivery) ─────────────────────────────────────────
# When unset in local dev, sending does NOT fail — the sign-in link is printed
# to the server console instead. In PRODUCTION, a missing or partially-set
# config (any of HOST/USER/PASS absent) means the link is NOT sent: an error is
# logged, but never the link itself. Set all four in production. For Gmail, use
# an app password (https://myaccount.google.com/apppasswords), not your real
# password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password

# ── Local development only ───────────────────────────────────────────────────
# With the dev server on a machine where Claude Code is installed and logged
# in, "1" routes KEYLESS examiner calls through the local `claude -p` CLI —
# tuning runs then draw on your claude.ai subscription quota instead of API
# credits. Ignored outside `npm run dev` (production never takes this path).
# A BYOK key pasted in Settings still takes precedence (tests the real API path).
DEV_CLAUDE_CLI=1

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public base URL used to build the emailed magic links. REQUIRED in
# production: the request's own Host header is forgeable, so emailed links are
# never built from it (if unset, no link is sent and an error is logged). In
# local dev it may be left unset — the request origin (localhost) is used.
APP_BASE_URL=https://your-app.vercel.app
