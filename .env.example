# PACES Buddy — environment variables. Copy to .env.local and fill in.
# Everything below is OPTIONAL: with all of it unset the app runs BYOK-only
# (each user pastes their own API key for the selected model's provider in
# Settings).

# ── Managed access (email + 6-digit-code sign-in, tiered, per-user metered) ──
# The managed door lets signed-in users practise on a server-held key, tiered
# by email domain and metered in USD per calendar month (Singapore time). It
# needs ALL THREE of DATABASE_URL + AUTH_SECRET + DEMO_GATEWAY_API_KEY — with
# any of them unset the door is OFF (fails closed) and the app stays
# BYOK-only. WHO may sign in is DATABASE config, not env: the allowed_domains
# + email_overrides tables (plain SQL edits, applied immediately, no redeploy
# — see README.md "Managed access"). Full design: SPEC.md "Managed access".

# Neon Postgres connection string, provisioned by the Vercel Marketplace
# integration (vercel integration add neon; then vercel env pull). Holds the
# managed-tier state: users, domain allow-lists, sign-in codes, the usage
# ledger, and balances. The managed tier is OFF without it. After setting it,
# apply the schema (idempotent) with: node scripts/migrate.mjs
DATABASE_URL=

# The server-held Vercel AI Gateway key the MANAGED tier spends (login-gated,
# per-user metered). ONE key + ONE top-up (in the Vercel dashboard) fans out
# to both managed models (Claude Sonnet 4.6 + DeepSeek V4 Pro) at zero markup.
# Create it at Vercel → AI Gateway → API Keys, top up the AI Gateway credit
# balance (leave auto-top-up OFF so the balance is a hard no-surprise-charge
# ceiling — the managed tier simply pauses when it hits zero), then set it
# here. It never leaves the server and is unreachable without a valid signed
# session whose tier covers the model and whose spend reservation succeeded.
DEMO_GATEWAY_API_KEY=

# Secret for HMAC-signing the stored sign-in-code hashes and the paces_session
# cookie. Required for the managed door. Generate: openssl rand -hex 32
AUTH_SECRET=

# Global managed-spend backstop: total USD across ALL managed users per
# Singapore calendar day. Bounds worst-case exposure regardless of the
# per-user monthly caps. Unset or invalid = the default, 5.
MANAGED_DAILY_CAP_USD=5

# ── Direct-provider server keys (escape hatch — unused by the managed door) ──
# The managed door only ever spends DEMO_GATEWAY_API_KEY. These stay wired for
# BYOK-direct testing or an off-Vercel deployment where the gateway isn't
# wanted. Providers: Anthropic (console.anthropic.com), DeepSeek
# (platform.deepseek.com), Moonshot/Kimi (platform.moonshot.ai), MiniMax
# (platform.minimax.io). Use spend-capped keys — each is the blast radius if
# abused. None of these ever leave the server.
DEMO_ANTHROPIC_API_KEY=
DEMO_DEEPSEEK_API_KEY=
DEMO_MOONSHOT_API_KEY=
DEMO_MINIMAX_API_KEY=

# ── SMTP (sends the 6-digit sign-in codes) ───────────────────────────────────
# When unset in local dev, sending does NOT fail — but the code is only printed
# to the server console if MANAGED_LOG_OTP=1 is ALSO set (below); otherwise an
# error is logged without the code. In PRODUCTION (and any non-dev env), a
# missing or partially-set config (any of HOST/USER/PASS absent) means the code
# is NOT sent and NEVER logged. Set all four in production. For Gmail, use an
# app password (https://myaccount.google.com/apppasswords), not your real
# password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password

# Dev-only escape hatch: with SMTP unconfigured AND NODE_ENV !== 'production',
# "1" prints the plaintext sign-in code to the server console so the flow can
# be exercised without a real mailbox. Absent by default — a live code is never
# logged unless this is deliberately set. Leave unset in production.
MANAGED_LOG_OTP=

# ── Local development only ───────────────────────────────────────────────────
# With the dev server on a machine where Claude Code is installed and logged
# in, "1" routes KEYLESS examiner calls through the local `claude -p` CLI —
# tuning runs then draw on your claude.ai subscription quota instead of API
# credits. Ignored outside `npm run dev` (production never takes this path).
# A BYOK key pasted in Settings still takes precedence (tests the real API path).
DEV_CLAUDE_CLI=1

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public base URL for any absolute URL the server builds. Nothing sign-in-
# critical rides on it any more — the emailed sign-in codes deliberately carry
# no links (institutional mail gateways rewrite or strip them), so this may be
# left unset; the request origin is used as the fallback where one is needed.
APP_BASE_URL=https://your-app.vercel.app
