# PACES Practice — environment variables. Copy to .env.local and fill in.
# Everything below is OPTIONAL: with all of it unset the app runs BYOK-only
# (each user pastes their own Anthropic key in Settings).

# ── Demo access gate (whitelisted magic-link sign-in) ────────────────────────
# Lets a small set of invited users practise on a server-held key with no BYOK
# friction. See SPEC.md "Demo access" and README.md for the full flow.

# Comma-separated emails allowed to request demo access.
# Matched case-insensitively and trimmed; empty/unset = nobody.
DEMO_WHITELIST=consultant@example.com

# Server-held Anthropic API key used for valid demo sessions. Unset = demo mode
# off. Use a spend-capped workspace key — it is the blast radius if abused.
# This key never leaves the server.
DEMO_ANTHROPIC_API_KEY=

# Secret for HMAC-signing magic-link tokens and the demo_session cookie.
# Required for demo mode. Generate one with: openssl rand -hex 32
AUTH_SECRET=

# ── SMTP (magic-link email delivery) ─────────────────────────────────────────
# When unset in local dev, sending does NOT fail — the sign-in link is printed
# to the server console instead. In PRODUCTION, a missing or partially-set
# config (any of HOST/USER/PASS absent) means the link is NOT sent: an error is
# logged, but never the link itself. Set all four in production. For Gmail, use
# an app password (https://myaccount.google.com/apppasswords), not your real
# password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public base URL used to build the emailed magic links. REQUIRED in
# production: the request's own Host header is forgeable, so emailed links are
# never built from it (if unset, no link is sent and an error is logged). In
# local dev it may be left unset — the request origin (localhost) is used.
APP_BASE_URL=https://your-app.vercel.app
