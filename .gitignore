# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# generated hidden corpus (answer keys, surrogate briefs, canonical notes) —
# built by scripts/build-content.mjs; NEVER commit (a public push would leak
# every answer key). Regenerate at deploy time instead.
/content/

# clinical-image assets copied in by build-content.mjs from ../_index/case_images.json.
# INTERIM: extracts from third-party study PDFs — kept out of git (uploaded from
# local disk at deploy, like content/). Swap to open-licensed images before this
# is committed anywhere public.
/public/case-images/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev Postgres (scripts/dev-db.mjs)
/.dev-pg
